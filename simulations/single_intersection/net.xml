    <!-- Traffic light logic: 8 phases (4 green × 30 s, 4 yellow × 3 s) -->
    <tlLogic id="TLS" type="static" programID="0" offset="0">
        <!-- Phase 0  action 0 : N-S through -->
        <phase duration="30" state="GGrrrrrr"/>
        <!-- Phase 1  yellow -->
        <phase duration="3"  state="yyrrrrrr"/>
        <!-- Phase 2  action 1 : N-S left -->
        <phase duration="30" state="rrGGrrrr"/>
        <!-- Phase 3  yellow -->
        <phase duration="3"  state="rryyrrrr"/>
        <!-- Phase 4  action 2 : E-W through -->
        <phase duration="30" state="rrrrGGrr"/>
        <!-- Phase 5  yellow -->
        <phase duration="3"  state="rrrryyrr"/>
        <!-- Phase 6  action 3 : E-W left -->
        <phase duration="30" state="rrrrrrGG"/>
        <!-- Phase 7  yellow -->
        <phase duration="3"  state="rrrrrryy"/>
    </tlLogic>

