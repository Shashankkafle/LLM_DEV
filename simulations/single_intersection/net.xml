<!--
    Single-intersection SUMO network — regenerated via netconvert from SUMO 1.26.0.

    NODE NAMING
      N, S, E, W : dead-end approach nodes (200 m from intersection centre)
      TLS         : central traffic-light junction at (200, 200)

    EDGE NAMING  {source}2{dest}
      Inbound  : N2TLS  S2TLS  E2TLS  W2TLS
      Outbound : TLS2N  TLS2S  TLS2E  TLS2W

    LANE IDs  {edge_id}_{lane_index}   (SUMO convention)
      Lane 0 = through movement (right / curb lane)
      Lane 1 = left-turn movement (left lane)
      Examples: W2TLS_0  W2TLS_1  N2TLS_0  N2TLS_1

    GREEN PHASE ACTION → SUMO PHASE INDEX  (see sumo_env.py)
      Action 0 → Phase 0  (N-S through, 30 s)
      Action 1 → Phase 2  (N-S left,    30 s)
      Action 2 → Phase 4  (E-W through, 30 s)
      Action 3 → Phase 6  (E-W left,    30 s)
      Odd phase indices are 3 s yellow transitions.

    TLS LINK INDEX ORDER  (state-string bit positions)
      0 : N2TLS_0 → TLS2S_0   N-S through from N
      1 : S2TLS_0 → TLS2N_0   N-S through from S
      2 : N2TLS_1 → TLS2E_0   N-S left    from N (→ east)
      3 : S2TLS_1 → TLS2W_0   N-S left    from S (→ west)
      4 : E2TLS_0 → TLS2W_0   E-W through from E
      5 : W2TLS_0 → TLS2E_0   E-W through from W
      6 : E2TLS_1 → TLS2S_0   E-W left    from E (→ south)
      7 : W2TLS_1 → TLS2N_0   E-W left    from W (→ north)
-->
<net version="1.20" junctionCornerDetail="5" limitTurnSpeed="5.50"
